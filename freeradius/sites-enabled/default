server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
    }

    listen {
        type = acct
        ipaddr = *
        port = 0
    }

    authorize {
        rest
        if (ok || updated) {
            update control {
                Auth-Type := Accept
            }
        }
        elsif (fail) {
            # auth-svc unreachable — fail open
            ok
            update control {
                Auth-Type := Accept
            }
        }
    }

    authenticate {
        Auth-Type Accept {
            ok
        }
    }

    post-auth {
        rest
        if (fail) {
            ok
        }

        Post-Auth-Type REJECT {
            rest
            if (fail) {
                ok
            }
        }
    }

    accounting {
        rest
        if (fail) {
            ok
        }
    }
}
