server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
    }

    listen {
        type = acct
        ipaddr = *
        port = 0
    }

    authorize {
        rest_health
        if (ok) {
            # Cache hit — API recently failed, skip rest and fail open
            update control {
                Auth-Type := Accept
            }
        }
        else {
            rest
            if (ok || updated) {
                update control {
                    Auth-Type := Accept
                }
            }
            elsif (fail) {
                # auth-svc unreachable — cache the failure and fail open
                update control {
                    Cache-TTL := 10
                }
                cache_rest_health
                ok
                update control {
                    Auth-Type := Accept
                }
            }
        }
    }

    authenticate {
        Auth-Type Accept {
            ok
        }
    }

    post-auth {
        acct_health
        if (ok) {
            # Cache hit — acct-svc recently failed, skip
            ok
        }
        else {
            rest
            if (fail) {
                update control {
                    Cache-TTL := 10
                }
                cache_acct_health
                ok
            }
        }

        Post-Auth-Type REJECT {
            acct_health
            if (ok) {
                ok
            }
            else {
                rest
                if (fail) {
                    update control {
                        Cache-TTL := 10
                    }
                    cache_acct_health
                    ok
                }
            }
        }
    }

    accounting {
        acct_health
        if (ok) {
            # Cache hit — acct-svc recently failed, skip
            ok
        }
        else {
            rest
            if (fail) {
                update control {
                    Cache-TTL := 10
                }
                cache_acct_health
                ok
            }
        }
    }
}
