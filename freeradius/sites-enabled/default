server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
    }

    listen {
        type = acct
        ipaddr = *
        port = 0
    }

    authorize {
        # Read-only cache check — do not create entry on miss
        update control {
            Cache-Read-Only := yes
        }
        rest_health
        if (ok) {
            # Cache hit — API recently failed, skip rest and fail open
            update control {
                Auth-Type := Accept
            }
        }
        else {
            rest
            if (ok || updated) {
                update control {
                    Auth-Type := Accept
                }
            }
            elsif (fail) {
                # auth-svc unreachable — write to cache and fail open
                update control {
                    Cache-Read-Only !* ANY
                }
                rest_health
                ok
                update control {
                    Auth-Type := Accept
                }
            }
        }
    }

    authenticate {
        Auth-Type Accept {
            ok
        }
    }

    post-auth {
        update control {
            Cache-Read-Only := yes
        }
        acct_health
        if (ok) {
            ok
        }
        else {
            rest
            if (fail) {
                update control {
                    Cache-Read-Only !* ANY
                }
                acct_health
                ok
            }
        }

        Post-Auth-Type REJECT {
            update control {
                Cache-Read-Only := yes
            }
            acct_health
            if (ok) {
                ok
            }
            else {
                rest
                if (fail) {
                    update control {
                        Cache-Read-Only !* ANY
                    }
                    acct_health
                    ok
                }
            }
        }
    }

    accounting {
        update control {
            Cache-Read-Only := yes
        }
        acct_health
        if (ok) {
            ok
        }
        else {
            rest
            if (fail) {
                update control {
                    Cache-Read-Only !* ANY
                }
                acct_health
                ok
            }
        }
    }
}
