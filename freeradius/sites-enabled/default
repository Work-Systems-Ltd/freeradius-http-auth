server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
    }

    listen {
        type = acct
        ipaddr = *
        port = 0
    }

    authorize {
        rest_health
        if (ok) {
            # Cache hit — API recently failed, skip rest and fail open
            update control {
                Auth-Type := Accept
            }
        }
        else {
            rest
            if (ok || updated) {
                update control {
                    Auth-Type := Accept
                }
            }
            elsif (fail || timeout) {
                # auth-svc unreachable — cache the failure and fail open
                update control {
                    Cache-TTL := 10
                }
                cache_rest_health
                ok
                update control {
                    Auth-Type := Accept
                }
            }
        }
    }

    authenticate {
        Auth-Type Accept {
            ok
        }
    }

    post-auth {
        rest
        if (fail) {
            ok
        }

        Post-Auth-Type REJECT {
            rest
            if (fail) {
                ok
            }
        }
    }

    accounting {
        rest
        if (fail) {
            ok
        }
    }
}
