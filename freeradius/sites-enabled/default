server default {
    listen {
        type = auth
        ipaddr = *
        port = 0
        recv_buff = 4194304
    }

    listen {
        type = acct
        ipaddr = *
        port = 0
        recv_buff = 4194304
    }

    authorize {
        update control {
            Cache-Read-Only := yes
        }
        rest_health
        if (ok) {
            update control {
                Auth-Type := Accept
            }
        }
        else {
            load-balance {
                rest_auth1
                rest_auth2
            }
            if (ok || updated) {
                update control {
                    Auth-Type := Accept
                }
            }
            elsif (reject) {
                reject
            }
            elsif (fail) {
                update control {
                    Cache-Read-Only !* ANY
                }
                rest_health
                ok
                update control {
                    Auth-Type := Accept
                }
            }
        }
    }

    authenticate {
        Auth-Type Accept {
            ok
        }
    }

    post-auth {
        acct_health
        if (ok) {
            ok
        }
        else {
            load-balance {
                rest_acct1
                rest_acct2
            }
            if (fail) {
                update control {
                    Cache-TTL := 10
                }
                acct_health
                ok
            }
        }

        Post-Auth-Type REJECT {
            acct_health
            if (ok) {
                ok
            }
            else {
                load-balance {
                    rest_acct1
                    rest_acct2
                }
                if (fail) {
                    update control {
                        Cache-TTL := 10
                    }
                    acct_health
                    ok
                }
            }
        }
    }

    preacct {
        ok
    }

    accounting {
        acct_health
        if (ok) {
            ok
        }
        else {
            load-balance {
                rest_acct1
                rest_acct2
            }
            if (fail) {
                update control {
                    Cache-TTL := 10
                }
                acct_health
                ok
            }
        }
    }
}
