cache rest_health {
    driver = "rlm_cache_rbtree"
    key = "rest_api_auth"
    ttl = 10

    update {
        &reply:Reply-Message := "auth-svc down"
    }
}

cache acct_health {
    driver = "rlm_cache_rbtree"
    key = "rest_api_acct"
    ttl = 10

    update {
        &reply:Reply-Message := "acct-svc down"
    }
}
